# ─────────────────────────────────────────────
# UGC Colombia — Variables de entorno
# Copia este archivo como .env.local y completa los valores
# NUNCA subas .env.local al repositorio
# ─────────────────────────────────────────────

# Supabase
NEXT_PUBLIC_SUPABASE_URL=https://xxxxxxxxxxxx.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=eyJhbGciOiJIUzI1NiIsInR5cCI6IkpXVCJ9...
SUPABASE_SERVICE_ROLE_KEY=eyJhbGciOiJIUzI1NiIsInR5cCI6IkpXVCJ9...

# Resend (emails transaccionales)
RESEND_API_KEY=re_xxxxxxxxxxxxxxxxxxxx
RESEND_FROM_EMAIL=hola@ugccolombia.co
RESEND_NOTIFY_EMAIL=founder@kreoon.com

# Site
NEXT_PUBLIC_SITE_URL=https://ugccolombia.co

# Analytics (opcional en desarrollo)
NEXT_PUBLIC_GA4_ID=G-XXXXXXXXXX
NEXT_PUBLIC_META_PIXEL_ID=

# n8n webhook para calificación de leads
N8N_WEBHOOK_URL=https://dev.kreoon.com/webhook/ugc-leads
N8N_WEBHOOK_SECRET=

# Cal.com
NEXT_PUBLIC_CALCOM_LINK=https://cal.com/ugccolombia/discovery
