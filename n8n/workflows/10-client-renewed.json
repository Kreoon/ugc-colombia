          { "node": "HTTP - WhatsApp Client Thanks", "type": "main", "index": 0 },
          { "node": "HTTP - Beehiiv Tag Renovado", "type": "main", "index": 0 },
          { "node": "HTTP - WhatsApp Team Celebrate", "type": "main", "index": 0 }
        ],
        [{ "node": "Supabase - Log Missing Client", "type": "main", "index": 0 }]
      ]
    },
    "Supabase - Update Client Plan": { "main": [[{ "node": "Supabase - Insert Renewal Record", "type": "main", "index": 0 }]] },
    "Supabase - Insert Renewal Record": { "main": [[{ "node": "Respond - Success", "type": "main", "index": 0 }]] },
    "Supabase - Log Missing Client": { "main": [[{ "node": "Respond - Client Not Found", "type": "main", "index": 0 }]] }
  },
  "active": false,
  "settings": {
    "executionOrder": "v1",
